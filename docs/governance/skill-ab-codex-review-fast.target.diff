--- /dev/null
+++ b/skill_ab_target/tests/test_review_target.py
@@ -0,0 +1,15 @@
+from skill_ab_target.review_target import Policy, authorize_change
+
+
+class Request:
+    def __init__(self, risk_score=1, user_is_admin=False, owner_approved=False, state="draft"):
+        self.risk_score = risk_score
+        self.user_is_admin = user_is_admin
+        self.owner_approved = owner_approved
+        self.state = state
+
+
+def test_owner_approved_change_is_allowed():
+    policy = Policy(max_risk=5, require_owner=True, blocked_states={"locked"})
+    request = Request(owner_approved=True)
+    assert authorize_change(request, policy) == "allow"
