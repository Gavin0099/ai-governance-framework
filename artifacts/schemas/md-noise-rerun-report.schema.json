{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "md-noise-rerun-report.schema.json",
  "title": "MD Noise Rerun Report",
  "type": "object",
  "required": [
    "contract_id",
    "generated_at_utc",
    "contract_path",
    "actionability_patterns",
    "oracle_policy",
    "tooling",
    "repos"
  ],
  "properties": {
    "contract_id": {
      "type": "string"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "contract_path": {
      "type": "string"
    },
    "noise_phrase": {
      "type": "string"
    },
    "directional_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actionability_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "oracle_policy": {
      "type": "object",
      "required": [
        "statement",
        "injected_noise_exempted_only_in_injected_span",
        "reference_context_exemptions",
        "requires_actionability_context"
      ],
      "properties": {
        "statement": {
          "type": "string"
        },
        "injected_noise_exempted_only_in_injected_span": {
          "type": "boolean"
        },
        "reference_context_exemptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requires_actionability_context": {
          "type": "boolean"
        }
      }
    },
    "tooling": {
      "type": "object",
      "required": [
        "runner_script",
        "runner_sha256"
      ],
      "properties": {
        "runner_script": {
          "type": "string"
        },
        "runner_sha256": {
          "type": "string"
        }
      }
    },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "repo",
          "repo_path",
          "targets_requested",
          "targets_scanned",
          "missing_targets",
          "results",
          "aggregate"
        ],
        "properties": {
          "repo": {
            "type": "string"
          },
          "repo_path": {
            "type": "string"
          },
          "targets_requested": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "targets_scanned": {
            "type": "integer",
            "minimum": 0
          },
          "missing_targets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "file",
                "clean_directional",
                "noise_directional",
                "clean_status",
                "noise_status",
                "classification",
                "directional_synthesis",
                "actionability_source",
                "clean_oracle",
                "noise_oracle"
              ],
              "properties": {
                "file": {
                  "type": "string"
                },
                "clean_directional": {
                  "type": "boolean"
                },
                "noise_directional": {
                  "type": "boolean"
                },
                "clean_status": {
                  "type": "string",
                  "enum": [
                    "pass",
                    "fail"
                  ]
                },
                "noise_status": {
                  "type": "string",
                  "enum": [
                    "pass",
                    "fail"
                  ]
                },
                "classification": {
                  "type": "string"
                },
                "directional_synthesis": {
                  "type": "string",
                  "enum": [
                    "yes",
                    "no"
                  ]
                },
                "actionability_source": {
                  "type": "string",
                  "enum": [
                    "fact_fields",
                    "directional_summary"
                  ]
                },
                "clean_oracle": {
                  "type": "object",
                  "required": [
                    "directional_match_count",
                    "non_exempt_directional_count",
                    "actionability_context",
                    "directional_synthesis"
                  ],
                  "properties": {
                    "directional_match_count": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "non_exempt_directional_count": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "actionability_context": {
                      "type": "boolean"
                    },
                    "directional_synthesis": {
                      "type": "boolean"
                    }
                  }
                },
                "noise_oracle": {
                  "type": "object",
                  "required": [
                    "directional_match_count",
                    "non_exempt_directional_count",
                    "actionability_context",
                    "directional_synthesis"
                  ],
                  "properties": {
                    "directional_match_count": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "non_exempt_directional_count": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "actionability_context": {
                      "type": "boolean"
                    },
                    "directional_synthesis": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "aggregate": {
            "type": "object",
            "required": [
              "any_clean_fail",
              "any_noise_fail",
              "closure_gate",
              "scope_filter_compliance"
            ],
            "properties": {
              "any_clean_fail": {
                "type": "boolean"
              },
              "any_noise_fail": {
                "type": "boolean"
              },
              "closure_gate": {
                "type": "string",
                "enum": [
                  "pass",
                  "fail"
                ]
              },
              "scope_filter_compliance": {
                "type": "string",
                "enum": [
                  "verified",
                  "unverified"
                ]
              }
            }
          }
        }
      }
    }
  }
}
