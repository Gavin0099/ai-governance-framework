#!/bin/sh

REMOTE_NAME="$1"

EXPECTED_ORIGIN_PUSHURL="https://github.com/Gavin0099/ai-governance-framework.git"
EXPECTED_GITLAB_PUSHURL="https://GavinWu@gli-gitlab-ee.genesyslogic.com.tw/CRD/SW/ai-governance-framework/ai-governance-framework.git"

EXPECTED_ORIGIN_USER_NAME="Gavin0099"
EXPECTED_ORIGIN_USER_EMAIL="Gavin0099@users.noreply.github.com"
EXPECTED_GITLAB_USER_NAME="GavinWu"
EXPECTED_GITLAB_USER_EMAIL="Gavin.Wu@genesyslogic.com.tw"

actual_pushurl="$(git remote get-url --push "$REMOTE_NAME" 2>/dev/null)"
actual_user_name="$(git config --get user.name 2>/dev/null)"
actual_user_email="$(git config --get user.email 2>/dev/null)"

if [ "$REMOTE_NAME" = "origin" ]; then
  if [ "$actual_pushurl" != "$EXPECTED_ORIGIN_PUSHURL" ]; then
    echo "ERROR: origin pushurl mismatch."
    echo "Expected: $EXPECTED_ORIGIN_PUSHURL"
    echo "Actual:   $actual_pushurl"
    exit 1
  fi
  if [ "$actual_user_name" != "$EXPECTED_ORIGIN_USER_NAME" ] || [ "$actual_user_email" != "$EXPECTED_ORIGIN_USER_EMAIL" ]; then
    echo "ERROR: git identity mismatch."
    echo "Expected: $EXPECTED_ORIGIN_USER_NAME <$EXPECTED_ORIGIN_USER_EMAIL>"
    echo "Actual:   $actual_user_name <$actual_user_email>"
    exit 1
  fi
  exit 0
fi

if [ "$REMOTE_NAME" = "gitlab" ]; then
  if [ "$actual_pushurl" != "$EXPECTED_GITLAB_PUSHURL" ]; then
    echo "ERROR: gitlab pushurl mismatch."
    echo "Expected: $EXPECTED_GITLAB_PUSHURL"
    echo "Actual:   $actual_pushurl"
    exit 1
  fi
  if [ "$actual_user_name" != "$EXPECTED_GITLAB_USER_NAME" ] || [ "$actual_user_email" != "$EXPECTED_GITLAB_USER_EMAIL" ]; then
    echo "ERROR: git identity mismatch."
    echo "Expected: $EXPECTED_GITLAB_USER_NAME <$EXPECTED_GITLAB_USER_EMAIL>"
    echo "Actual:   $actual_user_name <$actual_user_email>"
    exit 1
  fi
  exit 0
fi

# Unmanaged remotes: allow by default.
exit 0
