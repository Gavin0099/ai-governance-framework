#!/usr/bin/env bash
# pre-push hook — AI Governance Framework
#
# push 前執行 contract_validator 檢查（若有待驗證的 AI 回覆快照）。
#
# 目前為「軟性」：僅輸出警告，不擋 push。
# 若需硬性擋截，將最後的 exit 0 改為 exit 1。
#
# 安裝方式：
#   bash scripts/install-hooks.sh

set -euo pipefail

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TARGET_REPO_ROOT="$(git -C "$HOOK_DIR" rev-parse --show-toplevel 2>/dev/null || pwd)"
FRAMEWORK_ROOT="${AI_GOVERNANCE_FRAMEWORK_ROOT:-}"
HOOK_CONFIG="$HOOK_DIR/ai-governance-framework-root"
if [ -z "$FRAMEWORK_ROOT" ] && [ -f "$HOOK_CONFIG" ]; then
    FRAMEWORK_ROOT="$(cat "$HOOK_CONFIG")"
fi
if [ -z "$FRAMEWORK_ROOT" ]; then
    FRAMEWORK_ROOT="$TARGET_REPO_ROOT"
fi

PYTHON_LIB="$FRAMEWORK_ROOT/scripts/lib/python.sh"
if [ ! -f "$PYTHON_LIB" ]; then
    echo "⚠️  [governance] 找不到 framework Python helper: $PYTHON_LIB"
    exit 0
fi
. "$PYTHON_LIB"

TOOL="$FRAMEWORK_ROOT/governance_tools/contract_validator.py"
DAILY_MEMORY_GUARD="$FRAMEWORK_ROOT/governance_tools/daily_memory_guard.py"
VERSION_BUMP_GUARD="$FRAMEWORK_ROOT/governance_tools/version_bump_guard.py"
SNAPSHOT_DIR="$TARGET_REPO_ROOT/memory/governance_snapshots"
RUNTIME_SCRIPT="$FRAMEWORK_ROOT/scripts/run-runtime-governance.sh"

if [ ! -f "$TOOL" ]; then
    exit 0
fi

if [ ! -d "$SNAPSHOT_DIR" ]; then
    exit 0
fi

if ! set_python_cmd; then
    echo "⚠️  [governance] 找不到 Python，略過合規快照驗證"
fi

FAIL_COUNT=0
for snapshot in "$SNAPSHOT_DIR"/*.txt; do
    [ -f "$snapshot" ] || continue
    [ "${#PYTHON_CMD[@]}" -gt 0 ] || break
    RESULT=$("${PYTHON_CMD[@]}" "$TOOL" --file "$snapshot" --format json 2>/dev/null) || true
    STATUS=$(echo "$RESULT" | "${PYTHON_CMD[@]}" -c "import sys,json; d=json.load(sys.stdin); print(d.get('valid',True))" 2>/dev/null || echo "true")
    if [ "$STATUS" = "False" ]; then
        echo "⚠️  [governance] 合規快照不通過: $(basename "$snapshot")"
        FAIL_COUNT=$((FAIL_COUNT + 1))
    fi
done

if [ "$FAIL_COUNT" -gt 0 ]; then
    echo ""
    echo "⚠️  [governance] ${FAIL_COUNT} 個 AI 回覆快照驗證不通過"
    echo "   如需強制 push: git push --no-verify"
    echo ""
fi

if [ -f "$RUNTIME_SCRIPT" ]; then
    echo "[governance] running runtime-governance enforcement before push"
    if ! (cd "$FRAMEWORK_ROOT" && bash "$RUNTIME_SCRIPT" --mode enforce); then
        echo ""
        echo "[governance] runtime-governance enforcement failed"
        echo "  fix the runtime governance failures before push"
        echo "  bypass once: git push --no-verify"
        echo ""
        exit 1
    fi
fi

if [ -f "$DAILY_MEMORY_GUARD" ] && [ "${#PYTHON_CMD[@]}" -gt 0 ]; then
    DAILY_MEMORY_WARNING=$("${PYTHON_CMD[@]}" "$DAILY_MEMORY_GUARD" --project-root "$TARGET_REPO_ROOT" --format human 2>/dev/null || true)
    if [ -n "$DAILY_MEMORY_WARNING" ]; then
        echo "$DAILY_MEMORY_WARNING"
    fi
fi

if [ -f "$VERSION_BUMP_GUARD" ] && [ "${#PYTHON_CMD[@]}" -gt 0 ]; then
    echo "[governance] version bump recommendation (advisory)"
    (
        cd "$TARGET_REPO_ROOT"
        "${PYTHON_CMD[@]}" "$VERSION_BUMP_GUARD" --base-ref origin/main --head-ref HEAD --format human
    ) || (
        cd "$TARGET_REPO_ROOT"
        "${PYTHON_CMD[@]}" "$VERSION_BUMP_GUARD" --base-ref HEAD~1 --head-ref HEAD --format human
    ) || true
fi

exit 0
